---
import Layout from '../layouts/Layout.astro';
import { STATE_TAX } from '../data/taxRates.js';

const stateList = Object.entries(STATE_TAX)
  .map(([abbr, s]) => ({ abbr, name: s.name }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout
  title="US Paycheck Calculator — Free Take-Home Pay Estimator 2025"
  description="Calculate your exact US take-home pay after federal tax, state tax, Social Security, and Medicare. Updated 2025 tax rates for all 50 states."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <h1>US Paycheck Calculator</h1>
      <p class="hero-sub">
        Calculate your exact take-home pay after federal&nbsp;tax, state&nbsp;tax,
        Social&nbsp;Security, and Medicare — all 50&nbsp;states, 2025 rates.
      </p>
    </div>
  </section>

  <!-- ── Ad slot: top leaderboard ──────────────────────────────────────────── -->
  <div class="ad-wrap">
    <div class="ad-slot ad-leaderboard">
      <!-- AdSense: 728×90 leaderboard -->
    </div>
  </div>

  <!-- ── Calculator ────────────────────────────────────────────────────────── -->
  <section class="calc-section">
    <div class="calc-center">

      <!-- Form card -->
      <div class="card form-card">
        <h2 class="card-title">Enter Your Details</h2>

        <!-- Pay type toggle -->
        <div class="field">
          <label class="field-label">Pay Type</label>
          <div class="toggle-row">
            <button id="btn-annual" class="toggle-btn active" type="button">Annual Salary</button>
            <button id="btn-hourly" class="toggle-btn"        type="button">Hourly Wage</button>
          </div>
        </div>

        <!-- Amount -->
        <div class="field">
          <label class="field-label" for="payAmount" id="payLabel">Annual Salary</label>
          <div class="input-wrap">
            <span class="prefix">$</span>
            <input type="number" id="payAmount" class="input" placeholder="75,000" min="0" step="1000" />
          </div>
        </div>

        <!-- Hours/week — shown only for hourly -->
        <div class="field" id="hoursField" style="display:none">
          <label class="field-label" for="hoursPerWeek">Hours per Week</label>
          <input type="number" id="hoursPerWeek" class="input" placeholder="40" min="1" max="168" value="40" />
        </div>

        <!-- Two-column row: State + Filing status -->
        <div class="field-row">
          <div class="field">
            <label class="field-label" for="stateSelect">State</label>
            <select id="stateSelect" class="input">
              <option value="">— Select state —</option>
              {stateList.map(s => (
                <option value={s.abbr}>{s.name}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label class="field-label" for="filingStatus">Filing Status</label>
            <select id="filingStatus" class="input">
              <option value="single">Single</option>
              <option value="married">Married Filing Jointly</option>
            </select>
          </div>
        </div>

        <!-- Dependents -->
        <div class="field">
          <label class="field-label" for="dependents">
            Dependents <span class="hint">(children under 17 — Child Tax Credit)</span>
          </label>
          <input type="number" id="dependents" class="input input-narrow" min="0" max="20" value="0" />
        </div>

        <button id="calcBtn" class="calc-btn" type="button">
          Calculate Take-Home Pay →
        </button>

        <p class="disclaimer">
          Based on 2025 federal and state tax rates. Does not include local taxes or pre-tax benefit deductions.
        </p>
      </div>

      <!-- Results card (appears below the form after calculate) -->
      <div class="card results-card" id="resultsCard">
        <div id="resultsPlaceholder" class="results-placeholder">
          <div class="placeholder-icon">📊</div>
          <p>Enter your details above and click <strong>Calculate</strong> to see your breakdown.</p>
        </div>

        <div id="resultsContent" style="display:none">
          <!-- Summary bar -->
          <div class="results-summary">
            <div class="summary-item">
              <span class="summary-label">Gross Income</span>
              <span class="summary-value" id="r-gross">—</span>
            </div>
            <div class="summary-arrow">→</div>
            <div class="summary-item highlight">
              <span class="summary-label">Take-Home Pay</span>
              <span class="summary-value green" id="r-net-annual">—</span>
            </div>
          </div>

          <!-- Period selector -->
          <div class="period-tabs">
            <button class="period-btn active" data-period="annual">Annual</button>
            <button class="period-btn" data-period="monthly">Monthly</button>
            <button class="period-btn" data-period="biweekly">Biweekly</button>
            <button class="period-btn" data-period="weekly">Weekly</button>
            <button class="period-btn" data-period="daily">Daily</button>
          </div>

          <!-- Breakdown -->
          <div class="breakdown">
            <div class="breakdown-row gross-row">
              <span class="breakdown-label">Gross Income</span>
              <span class="breakdown-value" id="r-gross-b">—</span>
            </div>
            <div class="breakdown-sep">Deductions</div>
            <div class="breakdown-row">
              <span class="breakdown-label">Federal Income Tax</span>
              <span class="breakdown-value neg" id="r-federal">—</span>
            </div>
            <div class="breakdown-row">
              <span class="breakdown-label">
                State Income Tax
                <span class="state-tag" id="r-state-name"></span>
              </span>
              <span class="breakdown-value neg" id="r-state">—</span>
            </div>
            <div class="breakdown-row">
              <span class="breakdown-label">Social Security <em>(6.2%)</em></span>
              <span class="breakdown-value neg" id="r-ss">—</span>
            </div>
            <div class="breakdown-row">
              <span class="breakdown-label">Medicare <em>(1.45%)</em></span>
              <span class="breakdown-value neg" id="r-medicare">—</span>
            </div>
            <div class="breakdown-row total-row">
              <span class="breakdown-label">Total Deductions</span>
              <span class="breakdown-value neg" id="r-deductions">—</span>
            </div>
            <div class="breakdown-row net-row">
              <span class="breakdown-label">Take-Home Pay</span>
              <span class="breakdown-value net" id="r-net">—</span>
            </div>
          </div>

          <!-- Effective rates -->
          <div class="rates-grid">
            <div class="rate-box">
              <div class="rate-value" id="r-eff-federal">—</div>
              <div class="rate-label">Federal Rate</div>
            </div>
            <div class="rate-box">
              <div class="rate-value" id="r-eff-state">—</div>
              <div class="rate-label">State Rate</div>
            </div>
            <div class="rate-box">
              <div class="rate-value" id="r-eff-total">—</div>
              <div class="rate-label">Total Rate</div>
            </div>
          </div>
        </div>
      </div>
      <!-- /Results card -->

    </div>
  </section>

  <!-- ── Ad slot: mid rectangle ────────────────────────────────────────────── -->
  <div class="ad-wrap">
    <div class="ad-slot ad-rectangle">
      <!-- AdSense: 300×250 rectangle -->
    </div>
  </div>

  <!-- ── How It Works ─────────────────────────────────────────────────────── -->
  <section class="info-section">
    <div class="container">
      <h2 class="section-title">How the Calculator Works</h2>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-icon">🏛️</div>
          <h3>Federal Income Tax</h3>
          <p>Uses the official 2025 progressive tax brackets after subtracting the standard deduction ($15,000 single / $30,000 married). Child Tax Credit ($2,000 per dependent) reduces your liability directly.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">🗺️</div>
          <h3>State Income Tax</h3>
          <p>Every state has different rules — from zero income tax (Texas, Florida, Nevada…) to progressive systems up to 13.3% (California). All 50 states use accurate 2025 rates.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">🔒</div>
          <h3>FICA Taxes</h3>
          <p>Social Security is 6.2% on the first $176,100 of wages (2025 wage base). Medicare is 1.45% on all wages, plus an additional 0.9% on income over $200,000 (single).</p>
        </div>
        <div class="info-card">
          <div class="info-icon">💰</div>
          <h3>Net Take-Home Pay</h3>
          <p>Results shown in five pay periods: annual, monthly (÷12), biweekly (÷26), weekly (÷52), and daily (÷260 working days per year).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Ad slot: before FAQ ───────────────────────────────────────────────── -->
  <div class="ad-wrap">
    <div class="ad-slot ad-leaderboard">
      <!-- AdSense: 728×90 leaderboard -->
    </div>
  </div>

  <!-- ── FAQ ──────────────────────────────────────────────────────────────── -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How accurate is this paycheck calculator?</summary>
          <p>This calculator uses official 2025 federal and state income tax brackets and standard deductions. It provides a close estimate for W-2 employees using standard deductions. It does not account for local/city taxes, state SDI, or pre-tax benefit deductions like 401(k) or health insurance premiums.</p>
        </details>
        <details class="faq-item">
          <summary>Which states have no income tax?</summary>
          <p>Nine states levy no state income tax on wages: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming.</p>
        </details>
        <details class="faq-item">
          <summary>What is the 2025 standard deduction?</summary>
          <p>The 2025 federal standard deduction is <strong>$15,000</strong> for single filers and <strong>$30,000</strong> for married filing jointly — up slightly from 2024 due to inflation adjustments.</p>
        </details>
        <details class="faq-item">
          <summary>What is FICA tax?</summary>
          <p>FICA consists of Social Security (6.2% on wages up to $176,100 in 2025) and Medicare (1.45% on all wages). Your employer matches these — so the government receives 12.4% + 2.9% total.</p>
        </details>
        <details class="faq-item">
          <summary>How do dependents affect my taxes?</summary>
          <p>Qualifying children under age 17 are eligible for the Child Tax Credit of up to $2,000 each. This directly reduces your federal tax liability (not just taxable income), giving you a larger paycheck.</p>
        </details>
        <details class="faq-item">
          <summary>What is the difference between marginal and effective tax rate?</summary>
          <p>Your marginal rate is your highest tax bracket rate. Your effective rate is total tax ÷ gross income — always lower because lower-income dollars are taxed at lower rates first.</p>
        </details>
      </div>
    </div>
  </section>

</Layout>

<!-- ─────────────────────────────────────────────────────────────────────────── -->
<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    background: linear-gradient(135deg, #1a56db 0%, #1447c0 100%);
    color: #fff;
    padding: 52px 20px 48px;
    text-align: center;
  }
  .hero h1 { font-size: clamp(1.75rem, 4vw, 2.6rem); font-weight: 800; margin-bottom: 12px; }
  .hero-sub { font-size: 1.05rem; opacity: .88; max-width: 540px; margin: 0 auto; }

  /* ── Ad slots ─────────────────────────────────────── */
  .ad-wrap {
    display: flex;
    justify-content: center;
    padding: 16px 20px;
    background: #f9fafb;
  }
  .ad-slot {
    background: #f3f4f6;
    border: 1.5px dashed #d1d5db;
    border-radius: 8px;
  }
  .ad-leaderboard { width: 100%; max-width: 728px; height: 90px; }
  .ad-rectangle   { width: 300px; height: 250px; }

  /* ── Calculator section ───────────────────────────── */
  .calc-section { padding: 36px 20px 24px; }
  .calc-center  { max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }

  /* ── Cards ────────────────────────────────────────── */
  .card {
    box-sizing: border-box;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 28px 32px;
    box-shadow: 0 2px 8px rgba(0,0,0,.06);
  }
  .card-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; color: #111827; }

  /* ── Form ─────────────────────────────────────────── */
  .field { margin-bottom: 16px; }
  .input-narrow { max-width: 120px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  @media (max-width: 500px) { .field-row { grid-template-columns: 1fr; } }

  .field-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 6px;
  }
  .field-label .hint { font-weight: 400; color: #9ca3af; margin-left: 4px; font-size: 0.8rem; white-space: nowrap; }

  .input-wrap { position: relative; box-sizing: border-box; width: 100%; }
  .prefix {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
    font-size: 0.95rem;
    pointer-events: none;
  }
  .input-wrap .input { padding-left: 28px; }

  .input {
    box-sizing: border-box;
    width: 100%;
    padding: 10px 12px;
    border: 1.5px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.95rem;
    color: #111827;
    background: #fff;
    transition: border-color .15s, box-shadow .15s;
    appearance: auto;
  }
  .input:focus { outline: none; border-color: #1a56db; box-shadow: 0 0 0 3px rgba(26,86,219,.12); }

  /* ── Toggle ───────────────────────────────────────── */
  .toggle-row { display: flex; gap: 8px; }
  .toggle-btn {
    flex: 1;
    padding: 9px 14px;
    border: 1.5px solid #d1d5db;
    border-radius: 8px;
    background: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    cursor: pointer;
    transition: all .15s;
  }
  .toggle-btn.active  { border-color: #1a56db; background: #e8f0fe; color: #1a56db; font-weight: 600; }
  .toggle-btn:hover:not(.active) { border-color: #9ca3af; background: #f9fafb; }

  /* ── Calculate button ─────────────────────────────── */
  .calc-btn {
    width: 100%;
    padding: 14px;
    background: #1a56db;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background .15s, transform .1s;
    margin-top: 6px;
    letter-spacing: 0.01em;
  }
  .calc-btn:hover  { background: #1447c0; }
  .calc-btn:active { transform: scale(.99); }

  .disclaimer { margin-top: 10px; font-size: 0.77rem; color: #9ca3af; text-align: center; line-height: 1.5; }

  /* ── Results placeholder ──────────────────────────── */
  .results-placeholder { text-align: center; padding: 36px 20px; color: #9ca3af; }
  .placeholder-icon { font-size: 2.2rem; margin-bottom: 10px; }
  .results-placeholder p { font-size: 0.9rem; }
  .results-placeholder strong { color: #1a56db; }

  /* ── Results summary bar ──────────────────────────── */
  .results-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 20px;
    padding: 16px 20px;
    background: #f9fafb;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    flex-wrap: wrap;
  }
  .summary-item { text-align: center; }
  .summary-item.highlight { }
  .summary-arrow { font-size: 1.4rem; color: #9ca3af; }
  .summary-label { display: block; font-size: 0.75rem; color: #9ca3af; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
  .summary-value { font-size: 1.3rem; font-weight: 800; color: #111827; }
  .summary-value.green { color: #16a34a; }

  /* ── Period tabs ──────────────────────────────────── */
  .period-tabs { display: flex; gap: 4px; background: #f3f4f6; border-radius: 8px; padding: 3px; margin-bottom: 18px; }
  .period-btn {
    flex: 1;
    padding: 7px 8px;
    border: none;
    border-radius: 6px;
    background: transparent;
    font-size: 0.8rem;
    font-weight: 500;
    color: #6b7280;
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
  }
  .period-btn.active { background: #fff; color: #1a56db; font-weight: 700; box-shadow: 0 1px 3px rgba(0,0,0,.1); }

  /* ── Breakdown table ──────────────────────────────── */
  .breakdown { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
  .breakdown-row { display: flex; justify-content: space-between; align-items: center; padding: 11px 16px; border-bottom: 1px solid #f3f4f6; }
  .breakdown-row:last-child { border-bottom: none; }
  .breakdown-label { font-size: 0.875rem; color: #374151; }
  .breakdown-label em { color: #9ca3af; font-style: normal; font-size: 0.8rem; }
  .state-tag { color: #9ca3af; font-size: 0.78rem; margin-left: 4px; }
  .breakdown-value { font-size: 0.95rem; font-weight: 600; color: #111827; }
  .breakdown-value.neg { color: #dc2626; }
  .breakdown-sep { padding: 5px 16px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #9ca3af; background: #f9fafb; }
  .gross-row { background: #f9fafb; }
  .total-row { background: #fff4f4; }
  .net-row   { background: #f0fdf4; }
  .net-row .breakdown-label { font-weight: 700; font-size: 0.95rem; }
  .breakdown-value.net { color: #16a34a; font-size: 1.05rem; }

  /* ── Effective rates ──────────────────────────────── */
  .rates-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 14px; }
  .rate-box { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; }
  .rate-value { font-size: 1.2rem; font-weight: 700; color: #1a56db; }
  .rate-label { font-size: 0.72rem; color: #6b7280; margin-top: 2px; }

  /* ── Info section ─────────────────────────────────── */
  .info-section { background: #f9fafb; padding: 56px 20px; }
  .section-title { font-size: 1.4rem; font-weight: 700; text-align: center; margin-bottom: 32px; }
  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; max-width: 1100px; margin: 0 auto; }
  .info-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 22px; }
  .info-icon { font-size: 1.6rem; margin-bottom: 10px; }
  .info-card h3 { font-size: 0.93rem; font-weight: 700; margin-bottom: 8px; }
  .info-card p  { font-size: 0.86rem; color: #6b7280; line-height: 1.65; }

  /* ── FAQ ──────────────────────────────────────────── */
  .faq-section { padding: 56px 20px; }
  .faq-list { max-width: 760px; margin: 0 auto; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 10px; margin-bottom: 8px; overflow: hidden; }
  .faq-item summary {
    padding: 15px 18px;
    font-weight: 600;
    font-size: 0.93rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #fff;
    transition: background .15s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: #1a56db; font-weight: 400; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item[open] summary { background: #f9fafb; }
  .faq-item p { padding: 12px 18px 16px; font-size: 0.875rem; color: #374151; line-height: 1.72; border-top: 1px solid #e5e7eb; }
</style>

<!-- ─────────────────────────────────────────────────────────────────────────── -->
<script>
  import {
    STATE_TAX,
    calcFederalTax,
    calcStateTax,
    calcFICA,
    calculatePaycheck,
  } from '../data/taxRates.js';

  // ── State ──────────────────────────────────────────────────────────────────
  let payType = 'annual';
  let activePeriod = 'annual';
  const DIVISORS = { annual: 1, monthly: 12, biweekly: 26, weekly: 52, daily: 260 };

  // ── DOM ────────────────────────────────────────────────────────────────────
  const btnAnnual    = document.getElementById('btn-annual');
  const btnHourly    = document.getElementById('btn-hourly');
  const hoursField   = document.getElementById('hoursField');
  const payLabel     = document.getElementById('payLabel');
  const payAmount    = document.getElementById('payAmount');
  const hoursInput   = document.getElementById('hoursPerWeek');
  const stateSelect  = document.getElementById('stateSelect');
  const filingStatus = document.getElementById('filingStatus');
  const dependents   = document.getElementById('dependents');
  const calcBtn      = document.getElementById('calcBtn');
  const placeholder  = document.getElementById('resultsPlaceholder');
  const content      = document.getElementById('resultsContent');

  // ── Pay type toggle ────────────────────────────────────────────────────────
  btnAnnual.addEventListener('click', () => {
    payType = 'annual';
    btnAnnual.classList.add('active');
    btnHourly.classList.remove('active');
    hoursField.style.display = 'none';
    payLabel.textContent = 'Annual Salary';
    payAmount.placeholder = '75,000';
    payAmount.step = '1000';
  });
  btnHourly.addEventListener('click', () => {
    payType = 'hourly';
    btnHourly.classList.add('active');
    btnAnnual.classList.remove('active');
    hoursField.style.display = '';
    payLabel.textContent = 'Hourly Wage';
    payAmount.placeholder = '25.00';
    payAmount.step = '0.25';
  });

  // ── Period tabs ────────────────────────────────────────────────────────────
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activePeriod = btn.dataset.period;
      if (lastResult) renderResult(lastResult);
    });
  });

  // ── Calculate ──────────────────────────────────────────────────────────────
  let lastResult = null;

  calcBtn.addEventListener('click', () => {
    const rawAmount = parseFloat(payAmount.value);
    if (!rawAmount || rawAmount <= 0) {
      payAmount.style.borderColor = '#dc2626';
      payAmount.focus();
      setTimeout(() => { payAmount.style.borderColor = ''; }, 1500);
      return;
    }

    const stateCode = stateSelect.value;
    const filing    = filingStatus.value;
    const deps      = Math.max(0, parseInt(dependents.value) || 0);
    const hours     = Math.max(1, parseFloat(hoursInput?.value) || 40);
    const gross     = payType === 'hourly' ? rawAmount * hours * 52 : rawAmount;

    lastResult = {
      ...calculatePaycheck({ gross, stateCode, filingStatus: filing, dependents: deps }),
      stateCode,
    };

    // Scroll to results
    document.getElementById('resultsCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
    renderResult(lastResult);
  });

  // Enter key support
  [payAmount, hoursInput, stateSelect, filingStatus, dependents].forEach(el => {
    el?.addEventListener('keydown', e => { if (e.key === 'Enter') calcBtn.click(); });
  });

  // ── Render ─────────────────────────────────────────────────────────────────
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function fmtPct(n) { return (n * 100).toFixed(1) + '%'; }
  function pa(annual) { return fmt(annual / DIVISORS[activePeriod]); }

  function renderResult(r) {
    placeholder.style.display = 'none';
    content.style.display = '';

    document.getElementById('r-gross').textContent     = fmt(r.gross);
    document.getElementById('r-net-annual').textContent = fmt(r.netPay);
    document.getElementById('r-gross-b').textContent   = pa(r.gross);
    document.getElementById('r-federal').textContent   = '−' + pa(r.federalTax);
    document.getElementById('r-state').textContent     = r.stateTax === 0 ? '$0 (no state tax)' : '−' + pa(r.stateTax);
    document.getElementById('r-ss').textContent        = '−' + pa(r.ss);
    document.getElementById('r-medicare').textContent  = '−' + pa(r.medicare);
    document.getElementById('r-deductions').textContent= '−' + pa(r.totalDeductions);
    document.getElementById('r-net').textContent       = pa(r.netPay);

    const sName = r.stateCode ? (STATE_TAX[r.stateCode]?.name ?? '') : '';
    document.getElementById('r-state-name').textContent = sName ? `(${sName})` : '';

    const g = r.gross;
    document.getElementById('r-eff-federal').textContent = g > 0 ? fmtPct(r.federalTax / g) : '0%';
    document.getElementById('r-eff-state').textContent   = g > 0 ? fmtPct(r.stateTax   / g) : '0%';
    document.getElementById('r-eff-total').textContent   = g > 0 ? fmtPct(r.totalDeductions / g) : '0%';
  }
</script>
